# Variables del proyecto INDUSECC OS.
# Configúralas en Vercel (Production, Preview y Development según corresponda).
# No subas un archivo .env real al repositorio.

# Proyecto Supabase conectado por el backend.
SUPABASE_URL=https://fexfgdttbowtjtppkmqj.supabase.co

# Privada: solo la usa /api/admin-users. Nunca la pongas en JavaScript del navegador.
SUPABASE_SERVICE_ROLE_KEY=pega_aqui_la_service_role_key

# Opcional: habilita NORA en /api/nora.
GOOGLE_API_KEY=pega_aqui_la_clave_de_gemini
GEMINI_MODEL=gemini-2.5-flash-lite

# Opcional: URL pública de la app para armar el enlace de los correos de acceso
# (invitación / restablecimiento de contraseña) que envía /api/admin-users.
# Si no se define, se calcula sola a partir del host de la petición.
APP_URL=https://indusecc-auditorias.vercel.app
